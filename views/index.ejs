<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheet/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Document</title>
</head>

<body>
    <div class="w-full h-full bg-zinc-900 text-white p-10">

        <div class="nav mb-10">
            <a href="/read" class="text-blue-500 ">Read User</a>
            <a href="/read" class="text-blue-500 "></a>
        </div>

        <label for="" class="text-3xl trracking-tighter">Create User</label>

        <form action="/create" method="post">
            <input type="text" class="px-5 py-3 bg-transparent rounded-xl border-2 border-zinc-700 outline-none text-sm"
                placeholder="name" name="name">

            <input type="text" class="px-5 py-3 bg-transparent rounded-xl border-2 border-zinc-700 outline-none text-sm"
                placeholder="email" name="email">

            <input type="text" class="px-5 py-3 bg-transparent rounded-xl border-2 border-zinc-700 outline-none text-sm"
                placeholder="image url " name="image">

            <input class="px-5 py-3 bg-blue-700 rounded-xl mt-5 text-sm" value="Create User" type="submit">
        </form>
    </div>
</body>

</html>