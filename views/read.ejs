<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheet/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Document</title>
</head>

<body>
    <div class="w-full bg-zinc-900 text-white p-10">

        <div class="nav mb-10">
            <a href="/" class="text-blue-500 ">Back To Home</a>
        </div>

        <label for="" class="text-3xl trracking-tighter">All Users</label>

        <div class="flex gap-2 flex-wrap mt-2">
            <% if(allUsers.length>0 ){ %>
                <% allUsers.forEach(user=>{ %>
                    <div class="users">
                        <div class="user w-72 p-4 bg-zinc-800 rounded-xl mt-5">
                            <div class="w-full h-52 rounded-lg bg-zinc-300 overflow-hidden">
                                <img src="<%= user.image %>" alt="" class="w-full h-full object-cover object-center">
                            </div>
                            <h3 class="text-xl tracking-tighter">
                                <%= user.name %>
                            </h3>
                            <h5 class="text-zinc-500">
                                <%= user.email %>
                            </h5>
                            <div class="flex justify-between items-center gap-3 mt-8">
                                <a class="text-blue-400" href="/edit/<%= user._id %>">Edit User</a>
                                <a class="text-red-500" href="/delete/<%= user._id %>">Delete User</a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else{ %>
                            <h2 class="text-red-600">No User</h2>
                            <% } %>


        </div>
    </div>
</body>

</html>